{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pliegocheck.local/schemas/restricted-env-v1.json",
  "title": "PliegoCheck restricted deployment environment",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "PLIEGOCHECK_DEPLOYMENT_MODE",
    "PLIEGOCHECK_PUBLIC_BASE_URL",
    "PLIEGOCHECK_ALLOWED_ORIGINS",
    "PLIEGOCHECK_TRUSTED_HOSTS",
    "PLIEGOCHECK_TRUSTED_PROXY_CIDRS",
    "PLIEGOCHECK_SECURE_COOKIES",
    "PLIEGOCHECK_SESSION_SECRET_FILE",
    "PLIEGOCHECK_SESSION_TTL_MINUTES",
    "PLIEGOCHECK_DATABASE_PASSWORD_FILE",
    "PLIEGOCHECK_DATABASE_URL_FILE",
    "PLIEGOCHECK_BOOTSTRAP_ADMIN_ENABLED",
    "PLIEGOCHECK_STORAGE_PATH",
    "PLIEGOCHECK_BACKUP_PATH",
    "PLIEGOCHECK_TLS_CERT_FILE",
    "PLIEGOCHECK_TLS_KEY_FILE",
    "PLIEGOCHECK_SECOP_ENABLED",
    "PLIEGOCHECK_MONITORING_ENABLED",
    "PLIEGOCHECK_EXTERNAL_DELIVERY_ENABLED",
    "PLIEGOCHECK_NOTIFICATION_DRY_RUN"
  ],
  "properties": {
    "PLIEGOCHECK_DEPLOYMENT_MODE": { "const": "restricted" },
    "PLIEGOCHECK_PUBLIC_BASE_URL": { "type": "string", "pattern": "^https://[^/]+(?::[0-9]+)?$" },
    "PLIEGOCHECK_ALLOWED_ORIGINS": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_TRUSTED_HOSTS": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_TRUSTED_PROXY_CIDRS": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_SECURE_COOKIES": { "const": "true" },
    "PLIEGOCHECK_SESSION_SECRET_FILE": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_SESSION_TTL_MINUTES": { "type": "integer", "minimum": 5, "maximum": 10080 },
    "PLIEGOCHECK_DATABASE_PASSWORD_FILE": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_DATABASE_URL_FILE": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_BOOTSTRAP_ADMIN_ENABLED": { "enum": ["true", "false"] },
    "PLIEGOCHECK_BOOTSTRAP_ADMIN_EMAIL": { "type": "string" },
    "PLIEGOCHECK_BOOTSTRAP_ADMIN_PASSWORD_FILE": { "type": "string" },
    "PLIEGOCHECK_STORAGE_PATH": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_BACKUP_PATH": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_TLS_CERT_FILE": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_TLS_KEY_FILE": { "type": "string", "minLength": 1 },
    "PLIEGOCHECK_LOG_LEVEL": { "enum": ["DEBUG", "INFO", "WARNING", "ERROR"] },
    "PLIEGOCHECK_SECOP_ENABLED": { "enum": ["true", "false"] },
    "PLIEGOCHECK_MONITORING_ENABLED": { "enum": ["true", "false"] },
    "PLIEGOCHECK_EXTERNAL_DELIVERY_ENABLED": { "enum": ["true", "false"] },
    "PLIEGOCHECK_NOTIFICATION_DRY_RUN": { "enum": ["true", "false"] }
  }
}
