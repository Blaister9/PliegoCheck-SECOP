# Copiar fuera del checkout. Todos los valores los proporciona el administrador institucional.
# Obligatorio, no sensible, reinicio requerido. Valor fijo seguro.
PLIEGOCHECK_DEPLOYMENT_MODE=restricted
# Obligatorio, no sensible, reinicio requerido. URL HTTPS autorizada, sin ruta.
PLIEGOCHECK_PUBLIC_BASE_URL=https://pliegocheck.example.invalid:8443
# Obligatorio, no sensible, reinicio requerido. Origins HTTPS exactos separados por coma.
PLIEGOCHECK_ALLOWED_ORIGINS=https://pliegocheck.example.invalid:8443
# Obligatorio, no sensible, reinicio requerido. Hosts exactos separados por coma; nunca *.
PLIEGOCHECK_TRUSTED_HOSTS=pliegocheck.example.invalid
# Obligatorio, no sensible, reinicio requerido. Solo CIDR/IP de la red Compose/proxy autorizada.
PLIEGOCHECK_TRUSTED_PROXY_CIDRS=172.16.0.0/12
# Obligatorio, no sensible, reinicio requerido. No cambiar en restricted.
PLIEGOCHECK_SECURE_COOKIES=true
# Obligatorio, sensible por referencia, reinicio requerido. Archivo externo, minimo 32 bytes.
PLIEGOCHECK_SESSION_SECRET_FILE=/srv/pliegocheck/secrets/session-secret
# Obligatorio, no sensible, reinicio requerido.
PLIEGOCHECK_SESSION_TTL_MINUTES=480
# Obligatorio, sensible por referencia, reinicio requerido.
PLIEGOCHECK_DATABASE_PASSWORD_FILE=/srv/pliegocheck/secrets/database-password
# Obligatorio, sensible por referencia, reinicio requerido. URL psycopg con host postgres.
PLIEGOCHECK_DATABASE_URL_FILE=/srv/pliegocheck/secrets/database-url
# Opcional y apagado por defecto. Habilitar solo para crear el primer ADMIN.
PLIEGOCHECK_BOOTSTRAP_ADMIN_ENABLED=false
# Requeridos unicamente durante bootstrap; no usar cuentas genericas permanentes.
PLIEGOCHECK_BOOTSTRAP_ADMIN_EMAIL=
PLIEGOCHECK_BOOTSTRAP_ADMIN_DISPLAY_NAME=Initial administrator
PLIEGOCHECK_BOOTSTRAP_ADMIN_PASSWORD_FILE=/srv/pliegocheck/secrets/bootstrap-admin-password
# Obligatorios, sensibles por contenido, persistentes y fuera del checkout.
PLIEGOCHECK_STORAGE_PATH=/srv/pliegocheck/storage
PLIEGOCHECK_BACKUP_PATH=/srv/pliegocheck/backups
# Obligatorios, sensibles por referencia, reinicio requerido. Certificado/cadena y clave externos.
PLIEGOCHECK_TLS_CERT_FILE=/srv/pliegocheck/tls/tls.crt
PLIEGOCHECK_TLS_KEY_FILE=/srv/pliegocheck/tls/tls.key
PLIEGOCHECK_TLS_MIN_DAYS=15
# Bind loopback seguro. Cambiar solo con firewall/VPN/allowlist institucional ya configurado.
PLIEGOCHECK_BIND_ADDRESS=127.0.0.1
PLIEGOCHECK_HTTP_PORT=8080
PLIEGOCHECK_HTTPS_PORT=8443
PLIEGOCHECK_LOG_LEVEL=INFO
PLIEGOCHECK_LOG_MAX_SIZE=10m
PLIEGOCHECK_LOG_MAX_FILES=5
PLIEGOCHECK_MIN_FREE_GB=5
# Capacidades opt-in; defaults seguros.
PLIEGOCHECK_SECOP_ENABLED=false
PLIEGOCHECK_SECOP_DOCUMENT_SYNC_ENABLED=false
PLIEGOCHECK_SECOP_DOCUMENT_DOWNLOAD_ENABLED=false
PLIEGOCHECK_MONITORING_ENABLED=false
PLIEGOCHECK_SCHEDULER_ENABLED=false
PLIEGOCHECK_EXTERNAL_DELIVERY_ENABLED=false
PLIEGOCHECK_NOTIFICATION_DRY_RUN=true
PLIEGOCHECK_EMAIL_ENABLED=false
PLIEGOCHECK_WEBHOOK_ENABLED=false
# Retencion en dias. La eliminacion real exige --confirm-retention.
PLIEGOCHECK_BACKUP_RETENTION_DAYS=30
PLIEGOCHECK_LOG_RETENTION_DAYS=30
