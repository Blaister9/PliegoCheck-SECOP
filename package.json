{
  "name": "pliegocheck-secop",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo de PliegoCheck-SECOP: plataforma multiagente de analisis GO / NO GO para procesos de contratacion publica en SECOP II",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @pliegocheck/web dev",
    "dev:api": "uv run uvicorn pliegocheck_api.main:app --reload --port 8000",
    "worker:health": "uv run pliegocheck-worker health",
    "worker:run-once": "uv run pliegocheck-worker run-once",
    "worker:drain": "uv run pliegocheck-worker drain",
    "normalization:run-once": "uv run pliegocheck-worker normalization-run-once",
    "normalization:drain": "uv run pliegocheck-worker normalization-drain",
    "normalization:test": "uv run pytest apps/worker/tests/test_requirement_normalization.py apps/api/tests/test_requirement_normalization_api.py packages/schemas/tests/test_normalized_requirement.py",
    "normalization:eval": "uv run pytest evals/requirement-normalization",
    "normalization:smoke": "uv run pliegocheck-worker normalization-smoke",
    "company:test": "uv run pytest apps/api/tests/test_company_profile_api.py packages/schemas/tests/test_company_profile_contracts.py",
    "company:snapshot-check": "uv run pytest apps/api/tests/test_company_profile_api.py::test_company_profile_complete_flow",
    "financial:test": "uv run pytest apps/api/tests/test_financial_evaluation_api.py apps/worker/tests/test_financial_evaluation.py packages/schemas/tests/test_financial_evaluation_contracts.py",
    "financial:eval": "uv run pytest evals/financial-evaluation",
    "financial:run-once": "uv run pliegocheck-worker financial-run-once",
    "financial:drain": "uv run pliegocheck-worker financial-drain",
    "decision:policy-check": "uv run pytest apps/worker/tests/test_decision_worker.py::test_policy_loads_with_stable_hash apps/worker/tests/test_decision_worker.py::test_policy_rejects_positive_uncertainty_behavior apps/worker/tests/test_decision_worker.py::test_policy_rejects_incomplete_precedence",
    "decision:test": "uv run pytest apps/worker/tests/test_decision_worker.py apps/api/tests/test_decision_api.py packages/schemas/tests/test_decision_contracts.py",
    "decision:eval": "uv run pytest evals/decision-engine",
    "decision:run-once": "uv run pliegocheck-worker decision-run-once",
    "decision:drain": "uv run pliegocheck-worker decision-drain",
    "report:test": "uv run pytest apps/api/tests/test_decision_report_api.py apps/worker/tests/test_decision_report_worker.py packages/schemas/tests/test_decision_report_contracts.py",
    "report:eval": "uv run pytest evals/decision-report",
    "report:run-once": "uv run pliegocheck-worker report-run-once",
    "report:drain": "uv run pliegocheck-worker report-drain",
    "auth:test": "uv run pytest apps/api/tests/test_auth_api.py packages/schemas/tests/test_auth_contracts.py",
    "ops:test": "uv run pytest apps/api/tests/test_ops.py",
    "pilot:eval": "uv run pytest evals/pilot-readiness evals/pilot-end-to-end packages/schemas/tests/test_pilot_contracts.py",
    "pilot:prepare": "uv run pliegocheck-worker pilot-prepare",
    "pilot:run": "uv run pliegocheck-worker pilot-run",
    "pilot:reset": "uv run pliegocheck-worker pilot-reset",
    "pilot:readiness": "uv run pliegocheck-worker pilot-readiness",
    "auth:create-admin": "uv run pliegocheck-api users create-admin",
    "auth:list-users": "uv run pliegocheck-api users list",
    "ops:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-local.ps1",
    "ops:restore": "powershell -ExecutionPolicy Bypass -File scripts/restore-local.ps1",
    "deployment:eval": "uv run pytest evals/deployment-readiness",
    "deployment:backup-check": "uv run pytest apps/api/tests/test_ops.py::test_backup_manifest_declares_hashes_and_excludes_secrets evals/deployment-readiness/test_deployment_readiness.py::test_report_storage_and_backup_manifest_are_controlled",
    "controlled:deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-controlled.ps1",
    "controlled:validate": "powershell -ExecutionPolicy Bypass -File scripts/validate-controlled.ps1",
    "controlled:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-controlled.ps1",
    "controlled:reset": "powershell -ExecutionPolicy Bypass -File scripts/reset-controlled.ps1",
    "controlled:eval": "uv run pytest evals/controlled-deployment/test_controlled_deployment.py",
    "controlled:data-scan": "uv run pytest evals/controlled-deployment/test_controlled_data_scan.py",
    "controlled:backup-check": "pnpm deployment:backup-check",
    "specialized:test": "uv run pytest apps/worker/tests/test_specialized_evaluators.py apps/api/tests/test_specialized_evaluations_api.py packages/schemas/tests/test_specialized_evaluation_contracts.py",
    "specialized:eval": "uv run pytest evals/specialized-evaluators",
    "specialized:run-once": "uv run pliegocheck-worker specialized-run-once",
    "specialized:drain": "uv run pliegocheck-worker specialized-drain",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down",
    "db:migrate": "node scripts/db.mjs migrate",
    "db:check": "node scripts/db.mjs check",
    "schemas:generate": "node scripts/generate-schemas.mjs",
    "schemas:check": "node scripts/generate-schemas.mjs --check",
    "format": "prettier --write . && uv run ruff format",
    "format:check": "prettier --check . && uv run ruff format --check",
    "lint": "eslint . && uv run ruff check",
    "typecheck": "pnpm -r typecheck && uv run mypy",
    "test": "pnpm -r test && uv run pytest",
    "extraction:test": "uv run pytest apps/worker/tests && uv run pytest apps/api/tests/test_process_import.py",
    "build": "pnpm --filter @pliegocheck/web build",
    "check": "pnpm schemas:check && pnpm auth:test && pnpm ops:test && pnpm pilot:eval && pnpm deployment:eval && pnpm deployment:backup-check && pnpm controlled:eval && pnpm controlled:data-scan && pnpm company:test && pnpm company:snapshot-check && pnpm normalization:test && pnpm normalization:eval && pnpm financial:test && pnpm financial:eval && pnpm specialized:test && pnpm specialized:eval && pnpm decision:policy-check && pnpm decision:test && pnpm decision:eval && pnpm report:test && pnpm report:eval && pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0"
  }
}
