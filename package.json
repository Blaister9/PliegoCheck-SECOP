{
  "name": "pliegocheck-secop",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo de PliegoCheck-SECOP: plataforma multiagente de analisis GO / NO GO para procesos de contratacion publica en SECOP II",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:web": "pnpm --filter @pliegocheck/web dev",
    "dev:api": "uv run uvicorn pliegocheck_api.main:app --reload --port 8000",
    "worker:health": "uv run pliegocheck-worker health",
    "infra:up": "docker compose up -d postgres",
    "infra:down": "docker compose down",
    "db:migrate": "node scripts/db.mjs migrate",
    "db:check": "node scripts/db.mjs check",
    "schemas:generate": "node scripts/generate-schemas.mjs",
    "schemas:check": "node scripts/generate-schemas.mjs --check",
    "format": "prettier --write . && uv run ruff format",
    "format:check": "prettier --check . && uv run ruff format --check",
    "lint": "eslint . && uv run ruff check",
    "typecheck": "pnpm -r typecheck && uv run mypy",
    "test": "pnpm -r test && uv run pytest",
    "build": "pnpm --filter @pliegocheck/web build",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm schemas:check && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0"
  }
}
