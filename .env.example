# Perfil local inseguro permitido solo en localhost:
# - PLIEGOCHECK_ENVIRONMENT=development
# - PLIEGOCHECK_PILOT_MODE=false
# - PLIEGOCHECK_AUTH_COOKIE_SECURE=false
# Perfil piloto controlado:
# - PLIEGOCHECK_ENVIRONMENT=pilot
# - PLIEGOCHECK_PILOT_MODE=true
# - PLIEGOCHECK_AUTH_ENABLED=true
# - PLIEGOCHECK_AUTH_COOKIE_SECURE=true con HTTPS
# - PLIEGOCHECK_CORS_ALLOWED_ORIGINS debe ser el origen exacto de la web, nunca '*'
# - PLIEGOCHECK_AUTH_SECRET_KEY debe venir de .env local o gestor de secretos
