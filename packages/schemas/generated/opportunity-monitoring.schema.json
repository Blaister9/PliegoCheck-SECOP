            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "input_digest": {
          "type": "string"
        },
        "monitor_id": {
          "format": "uuid",
          "type": "string"
        },
        "new_candidate_count": {
          "default": 0,
          "type": "integer"
        },
        "scheduled_for": {
          "format": "date-time",
          "type": "string"
        },
        "started_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
