{
  "$defs": {
    "ExternalProcurementSearchRequest": {
      "additionalProperties": false,
      "properties": {
        "closing_from": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "closing_to": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "department": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "entity_name": {
          "anyOf": [
            {
              "maxLength": 300,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "limit": {
          "default": 20,
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        },
        "max_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "min_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "modality": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "municipality": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "offset": {
          "default": 0,
          "maximum": 1000000,
          "minimum": 0,
          "type": "integer"
        },
        "process_code": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "published_from": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "published_to": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "query": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_system": {
          "$ref": "#/$defs/ExternalProcurementSourceSystem",
          "default": "SECOP_II"
        },
        "status": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "type": "object"
    },
    "ExternalProcurementSourceSystem": {
      "enum": ["SECOP_II", "SECOP_I"],
      "type": "string"
    },
    "OpportunityAlertAction": {
      "enum": ["MARK_READ", "MARK_UNREAD", "ARCHIVE", "RESTORE", "RESOLVE"],
      "type": "string"
    },
    "OpportunityAlertActionRequest": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/$defs/OpportunityAlertAction"
        }
      },
      "required": ["action"],
      "type": "object"
    },
    "OpportunityAlertActionResponse": {
      "additionalProperties": false,
      "properties": {
        "status": {
          "$ref": "#/$defs/OpportunityAlertStatus"
        },
        "updated_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": ["updated_ids", "status"],
      "type": "object"
    },
    "OpportunityAlertDetail": {
      "additionalProperties": false,
      "properties": {
        "alert_fingerprint": {
          "type": "string"
        },
        "alert_type": {
          "$ref": "#/$defs/OpportunityAlertType"
        },
        "archived_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "assessment_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "disclaimer": {
          "default": "Las alertas señalan novedades o cambios relevantes según la política configurada. No constituyen una recomendación automática de presentar oferta.",
          "type": "string"
        },
        "events": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "array"
        },
        "explanation_parameters": {
          "additionalProperties": true,
          "type": "object"
        },
        "first_seen_at": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "last_seen_at": {
          "format": "date-time",
          "type": "string"
        },
        "monitor_id": {
          "format": "uuid",
          "type": "string"
        },
        "monitor_run_id": {
          "format": "uuid",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "type": "string"
        },
        "opportunity_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "read_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason_code": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/OpportunityAlertSeverity"
        },
        "status": {
          "$ref": "#/$defs/OpportunityAlertStatus"
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "monitor_id",
        "monitor_run_id",
        "alert_type",
        "severity",
        "status",
        "title",
        "summary",
        "reason_code",
        "occurred_at",
        "first_seen_at",
        "last_seen_at",
        "explanation_parameters",
        "alert_fingerprint"
      ],
      "type": "object"
    },
    "OpportunityAlertDigest": {
      "additionalProperties": false,
      "properties": {
        "critical_closings": {
          "default": 0,
          "type": "integer"
        },
        "disclaimer": {
          "default": "Las alertas señalan novedades o cambios relevantes según la política configurada. No constituyen una recomendación automática de presentar oferta.",
          "type": "string"
        },
        "documents_and_addenda": {
          "default": 0,
          "type": "integer"
        },
        "generated_at": {
          "format": "date-time",
          "type": "string"
        },
        "monitor_failures": {
          "default": 0,
          "type": "integer"
        },
        "period": {
          "pattern": "^(TODAY|LAST_24_HOURS|LAST_7_DAYS)$",
          "type": "string"
        },
        "priority_opportunities": {
          "default": 0,
          "type": "integer"
        },
        "relevant_changes": {
          "default": 0,
          "type": "integer"
        },
        "total": {
          "default": 0,
          "type": "integer"
        }
      },
      "required": ["period", "generated_at"],
      "type": "object"
    },
    "OpportunityAlertList": {
      "additionalProperties": false,
      "properties": {
        "disclaimer": {
          "default": "Las alertas señalan novedades o cambios relevantes según la política configurada. No constituyen una recomendación automática de presentar oferta.",
          "type": "string"
        },
        "items": {
          "items": {
            "$ref": "#/$defs/OpportunityAlertSummary"
          },
          "type": "array"
        },
        "limit": {
          "type": "integer"
        },
        "offset": {
          "type": "integer"
        },
        "total": {
          "type": "integer"
        }
      },
      "required": ["items", "total", "limit", "offset"],
      "type": "object"
    },
    "OpportunityAlertRules": {
      "additionalProperties": false,
      "properties": {
        "addenda": {
          "default": true,
          "type": "boolean"
        },
        "alert_on_initial_results": {
          "default": false,
          "type": "boolean"
        },
        "closing_date_changes": {
          "default": true,
          "type": "boolean"
        },
        "compatibility_change_threshold": {
          "default": 10,
          "maximum": 100,
          "minimum": 1,
          "type": "number"
        },
        "compatibility_changes": {
          "default": true,
          "type": "boolean"
        },
        "critical_deadline": {
          "default": true,
          "type": "boolean"
        },
        "critical_hours": {
          "default": 48,
          "maximum": 168,
          "minimum": 1,
          "type": "integer"
        },
        "document_updates": {
          "default": true,
          "type": "boolean"
        },
        "minimum_compatibility_score": {
          "default": 0,
          "maximum": 100,
          "minimum": 0,
          "type": "number"
        },
        "minimum_information_completeness": {
          "default": 0,
          "maximum": 100,
          "minimum": 0,
          "type": "number"
        },
        "monitor_failures": {
          "default": true,
          "type": "boolean"
        },
        "new_documents": {
          "default": true,
          "type": "boolean"
        },
        "new_potential": {
          "default": true,
          "type": "boolean"
        },
        "new_review_first": {
          "default": true,
          "type": "boolean"
        },
        "outcome_changes": {
          "default": true,
          "type": "boolean"
        },
        "partner_needed": {
          "default": true,
          "type": "boolean"
        },
        "process_closed": {
          "default": true,
          "type": "boolean"
        },
        "urgent_days": {
          "default": 5,
          "maximum": 90,
          "minimum": 1,
          "type": "integer"
        },
        "urgent_deadline": {
          "default": true,
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "OpportunityAlertSeverity": {
      "enum": ["INFO", "LOW", "MEDIUM", "HIGH", "CRITICAL"],
      "type": "string"
    },
    "OpportunityAlertStatus": {
      "enum": ["UNREAD", "READ", "ARCHIVED", "RESOLVED"],
      "type": "string"
    },
    "OpportunityAlertSummary": {
      "additionalProperties": false,
      "properties": {
        "alert_type": {
          "$ref": "#/$defs/OpportunityAlertType"
        },
        "archived_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "assessment_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "first_seen_at": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "last_seen_at": {
          "format": "date-time",
          "type": "string"
        },
        "monitor_id": {
          "format": "uuid",
          "type": "string"
        },
        "monitor_run_id": {
          "format": "uuid",
          "type": "string"
        },
        "occurred_at": {
          "format": "date-time",
          "type": "string"
        },
        "opportunity_id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "read_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason_code": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/OpportunityAlertSeverity"
        },
        "status": {
          "$ref": "#/$defs/OpportunityAlertStatus"
        },
        "summary": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "monitor_id",
        "monitor_run_id",
        "alert_type",
        "severity",
        "status",
        "title",
        "summary",
        "reason_code",
        "occurred_at",
        "first_seen_at",
        "last_seen_at"
      ],
      "type": "object"
    },
    "OpportunityAlertType": {
      "enum": [
        "NEW_REVIEW_FIRST",
        "NEW_POTENTIAL_OPPORTUNITY",
        "NEW_PARTNER_NEEDED",
        "OPPORTUNITY_NOW_URGENT",
        "OPPORTUNITY_NOW_CRITICAL",
        "OUTCOME_IMPROVED",
        "OUTCOME_WORSENED",
        "COMPATIBILITY_INCREASED",
        "COMPATIBILITY_DECREASED",
        "CLOSING_DATE_CHANGED",
        "PROCESS_CLOSED",
        "NEW_DOCUMENT_DISCOVERED",
        "DOCUMENT_UPDATED",
        "POTENTIAL_ADDENDUM_DISCOVERED",
        "CONFIRMED_ADDENDUM_DISCOVERED",
        "DEEP_ANALYSIS_BLOCKED",
        "MONITOR_FAILURE",
        "MONITOR_RECOVERED"
      ],
      "type": "string"
    },
    "OpportunityAlertUnreadCount": {
      "additionalProperties": false,
      "properties": {
        "count": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": ["count"],
      "type": "object"
    },
    "OpportunityMonitorCreateRequest": {
      "additionalProperties": false,
      "properties": {
        "alert_rules": {
          "$ref": "#/$defs/OpportunityAlertRules"
        },
        "company_profile_id": {
          "format": "uuid",
          "type": "string"
        },
        "company_snapshot_id": {
          "format": "uuid",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "maxLength": 2000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "filters": {
          "$ref": "#/$defs/OpportunityMonitorFilters"
        },
        "frequency": {
          "$ref": "#/$defs/OpportunityMonitorFrequency"
        },
        "name": {
          "maxLength": 200,
          "minLength": 1,
          "type": "string"
        },
        "source_systems": {
          "items": {
            "$ref": "#/$defs/ExternalProcurementSourceSystem"
          },
          "maxItems": 2,
          "minItems": 1,
          "type": "array"
        },
        "timezone": {
          "default": "America/Bogota",
          "maxLength": 64,
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name",
        "company_profile_id",
        "company_snapshot_id",
        "frequency",
        "filters",
        "source_systems"
      ],
      "type": "object"
    },
