        "company_profile_id": {
          "format": "uuid",
          "type": "string"
        },
        "company_snapshot_id": {
          "format": "uuid",
          "type": "string"
        },
        "consecutive_failures": {
          "default": 0,
          "type": "integer"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "description": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "filters": {
          "$ref": "#/$defs/OpportunityMonitorFilters"
        },
        "frequency": {
          "$ref": "#/$defs/OpportunityMonitorFrequency"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "last_failure_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "last_run_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "last_success_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "latest_runs": {
          "items": {
            "$ref": "#/$defs/OpportunityMonitorRunSummary"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "next_run_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "policy_hash": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "source_systems": {
          "items": {
            "$ref": "#/$defs/ExternalProcurementSourceSystem"
          },
          "type": "array"
        },
        "status": {
          "$ref": "#/$defs/OpportunityMonitorStatus"
        },
        "timezone": {
          "type": "string"
        },
        "updated_at": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "company_profile_id",
        "company_snapshot_id",
        "policy_version",
        "policy_hash",
        "status",
        "frequency",
        "timezone",
        "source_systems",
        "created_at",
        "updated_at",
        "filters",
        "alert_rules"
      ],
      "type": "object"
    },
    "OpportunityMonitorFilters": {
      "additionalProperties": false,
      "properties": {
        "candidate_ids": {
          "items": {
            "format": "uuid",
            "type": "string"
          },
          "maxItems": 500,
          "type": "array"
        },
        "search_requests": {
          "items": {
            "$ref": "#/$defs/ExternalProcurementSearchRequest"
          },
          "maxItems": 10,
          "type": "array"
        }
      },
      "type": "object"
    },
    "OpportunityMonitorFrequency": {
      "enum": ["HOURLY", "EVERY_3_HOURS", "EVERY_6_HOURS", "EVERY_12_HOURS", "DAILY", "WEEKDAYS"],
      "type": "string"
