{
  "$defs": {
    "ExpectedValue": {
      "additionalProperties": false,
      "description": "Valor exigido por el pliego cuando existe soporte explicito.",
      "properties": {
        "raw_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "unit": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": ["value", "unit", "raw_text"],
      "type": "object"
    },
    "RequirementBasis": {
      "enum": ["EXPLICIT", "INFERRED", "UNKNOWN"],
      "type": "string"
    },
    "RequirementCategory": {
      "description": "Categorias iniciales de requisitos.",
      "enum": [
        "LEGAL",
        "FINANCIAL",
        "ORGANIZATIONAL",
        "EXPERIENCE",
        "TECHNICAL",
        "WORKFORCE",
        "GUARANTEE",
        "SCHEDULE",
        "ECONOMIC",
        "OPERATIONAL",
        "DOCUMENTARY",
        "RISK_AND_INELIGIBILITY"
      ],
      "type": "string"
    },
    "RequirementCriticality": {
      "enum": ["BLOCKING", "HIGH", "MEDIUM", "LOW", "INFORMATIONAL", "UNKNOWN"],
      "type": "string"
    },
    "RequirementEvidenceStatus": {
      "enum": ["VALIDATED", "PARTIALLY_VALIDATED", "REJECTED_UNSUPPORTED", "UNKNOWN"],
      "type": "string"
    },
    "RequirementModality": {
      "enum": ["MANDATORY", "OPTIONAL", "CONDITIONAL", "PROHIBITED", "UNKNOWN"],
      "type": "string"
    },
    "RequirementReviewStatus": {
      "enum": ["PENDING", "IN_REVIEW", "ACCEPTED", "REJECTED"],
      "type": "string"
    },
    "RequirementScope": {
      "enum": [
        "PROPOSAL_SUBMISSION",
        "HABILITATING",
        "SCORING",
        "CONTRACT_EXECUTION",
        "INFORMATIONAL",
        "UNKNOWN"
      ],
      "type": "string"
    },
    "RequirementSubsanability": {
      "enum": ["SUBSANABLE", "NON_SUBSANABLE", "CONDITIONAL", "UNKNOWN"],
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Requisito persistido tras validacion deterministica de evidencia.",
  "properties": {
    "category": {
      "$ref": "#/$defs/RequirementCategory"
    },
    "condition_text": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "type": "number"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "criticality": {
      "$ref": "#/$defs/RequirementCriticality"
    },
    "criticality_basis": {
      "$ref": "#/$defs/RequirementBasis"
    },
    "description": {
      "maxLength": 2000,
      "minLength": 1,
      "type": "string"
    },
    "evidence_status": {
      "$ref": "#/$defs/RequirementEvidenceStatus"
    },
    "expected_value": {
      "anyOf": [
        {
          "$ref": "#/$defs/ExpectedValue"
        },
        {
          "type": "null"
        }
      ]
    },
    "id": {
      "format": "uuid",
      "type": "string"
    },
    "is_active": {
      "type": "boolean"
    },
    "modality": {
      "$ref": "#/$defs/RequirementModality"
    },
    "normalization_run_id": {
      "format": "uuid",
      "type": "string"
    },
    "process_id": {
      "format": "uuid",
      "type": "string"
    },
    "requires_human_review": {
      "type": "boolean"
    },
    "review_status": {
      "$ref": "#/$defs/RequirementReviewStatus"
    },
    "scope": {
      "$ref": "#/$defs/RequirementScope"
    },
    "stable_key": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "subsanability": {
      "$ref": "#/$defs/RequirementSubsanability"
    },
    "subsanability_basis": {
      "$ref": "#/$defs/RequirementBasis"
    },
    "updated_at": {
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "id",
    "process_id",
    "normalization_run_id",
    "stable_key",
    "category",
    "scope",
    "modality",
    "description",
    "condition_text",
    "expected_value",
    "criticality",
    "criticality_basis",
    "subsanability",
    "subsanability_basis",
    "confidence",
    "evidence_status",
    "review_status",
    "requires_human_review",
    "is_active",
    "created_at",
    "updated_at"
  ],
  "type": "object"
}
