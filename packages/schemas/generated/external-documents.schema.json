      },
      "required": [
        "process_id",
        "external_document_id",
        "status",
        "version_id",
        "process_document_id",
        "sha256",
        "message"
      ],
      "type": "object"
    },
    "ExternalDocumentDownloadStatus": {
      "enum": [
        "NOT_REQUESTED",
        "PENDING",
        "DOWNLOADING",
        "DOWNLOADED",
        "UNCHANGED",
        "UPDATED",
        "UNSUPPORTED",
        "FAILED",
        "REJECTED"
