        "EXTERNAL_DOCUMENT_TOO_LARGE",
        "EXTERNAL_DOCUMENT_CONTENT_TYPE_REJECTED",
        "EXTERNAL_DOCUMENT_HTML_RESPONSE",
        "EXTERNAL_DOCUMENT_DOWNLOAD_FAILED",
