{
  "$defs": {
    "ExternalProcurementSearchRequest": {
      "additionalProperties": false,
      "properties": {
        "closing_from": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "closing_to": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "department": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "entity_name": {
          "anyOf": [
            {
              "maxLength": 300,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "limit": {
          "default": 20,
          "maximum": 100,
          "minimum": 1,
          "type": "integer"
        },
        "max_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "min_value": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "modality": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "municipality": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "offset": {
          "default": 0,
          "maximum": 1000000,
          "minimum": 0,
          "type": "integer"
        },
        "process_code": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "published_from": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "published_to": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "query": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_system": {
          "$ref": "#/$defs/ExternalProcurementSourceSystem",
          "default": "SECOP_II"
        },
        "status": {
          "anyOf": [
            {
              "maxLength": 200,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "type": "object"
    },
    "ExternalProcurementSourceSystem": {
      "enum": ["SECOP_II", "SECOP_I"],
      "type": "string"
    },
    "OpportunityAnalysisLevel": {
      "enum": ["METADATA_SCREENING", "DOCUMENT_SCREENING", "DEEP_ANALYSIS"],
      "type": "string"
    },
    "OpportunityAssessmentComponentDetail": {
      "additionalProperties": false,
      "properties": {
        "component": {
          "$ref": "#/$defs/OpportunityComponent"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/OpportunityAssessmentEvidence"
          },
          "type": "array"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "explanation": {
          "maxLength": 2000,
          "type": "string"
        },
        "explanation_parameters": {
          "additionalProperties": true,
          "type": "object"
        },
        "id": {
          "anyOf": [
            {
              "format": "uuid",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reason_code": {
          "maxLength": 500,
          "minLength": 1,
          "type": "string"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ]
        },
        "status": {
          "$ref": "#/$defs/OpportunityComponentStatus"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "weight": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ]
        },
        "weighted_score": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ]
        }
      },
      "required": [
        "component",
        "status",
        "score",
        "weight",
        "weighted_score",
        "reason_code",
        "explanation"
      ],
      "type": "object"
    },
    "OpportunityAssessmentDetail": {
      "additionalProperties": false,
      "properties": {
        "analysis_level": {
          "$ref": "#/$defs/OpportunityAnalysisLevel"
        },
        "candidate": {
          "$ref": "#/$defs/OpportunityCandidateSummary"
