        "components": {
          "items": {
            "$ref": "#/$defs/OpportunityAssessmentComponentDetail"
          },
          "type": "array"
        },
        "created_at": {
          "format": "date-time",
          "type": "string"
        },
        "days_remaining": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "effective_at": {
          "format": "date-time",
          "type": "string"
        },
        "id": {
          "format": "uuid",
          "type": "string"
        },
        "information_completeness": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ]
        },
        "input_digest": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "latest_review_action": {
          "anyOf": [
            {
              "$ref": "#/$defs/OpportunityReviewAction"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "missing_information": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object"
        },
        "outcome": {
          "$ref": "#/$defs/OpportunityOutcome"
        },
        "partner_reasons": {
          "items": {
            "additionalProperties": true,
            "type": "object"
          },
          "type": "array"
        },
        "policy_hash": {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "requires_human_review": {
          "type": "boolean"
        },
        "summary": {
          "type": "string"
        },
        "urgency_score": {
          "anyOf": [
            {
              "maximum": 100.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "pattern": "^(?!^[-+.]*$)[+-]?0*\\d*\\.?\\d*$",
              "type": "string"
            }
          ]
        },
        "urgency_status": {
          "$ref": "#/$defs/OpportunityUrgencyStatus"
        },
        "warnings": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "candidate_id",
        "company_snapshot_id",
        "policy_version",
        "policy_hash",
        "analysis_level",
        "outcome",
        "compatibility_score",
        "urgency_score",
        "information_completeness",
        "urgency_status",
        "requires_human_review",
        "input_digest",
        "summary",
        "effective_at",
        "created_at",
        "candidate",
        "components"
      ],
      "type": "object"
    },
